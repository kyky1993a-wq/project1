[Unit]
Description=육아일기 FastAPI 서버
After=network.target postgresql.service

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/diary-app/backend
ExecStart=/home/ubuntu/diary-app/backend/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
